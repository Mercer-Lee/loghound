# ============================================================
# Cloud log service credentials
# Fill in the sections you need; leave the rest blank.
# ============================================================

# Alibaba Cloud SLS (Simple Log Service)
SLS_ACCESS_KEY_ID=
SLS_ACCESS_KEY_SECRET=

# Tencent Cloud CLS (Cloud Log Service)
CLS_SECRET_ID=
CLS_SECRET_KEY=

# ============================================================
# Webhook task query (e.g. n8n, internal workflow engine)
# ============================================================
WEBHOOK_API_URL=
WEBHOOK_ERROR_API_URL=
WEBHOOK_TOKEN=

# ============================================================
# MongoDB
# ============================================================
# Production
MONGO_URI=
MONGO_DB=
# Test
TEST_MONGO_URI=
TEST_MONGO_DB=

# ============================================================
# SQL (MySQL, PostgreSQL, etc.)
# ============================================================
# Production
SQL_HOST=
SQL_PORT=
SQL_USER=
SQL_PASSWORD=
SQL_DATABASE=
SQL_DIALECT=
# Test
TEST_SQL_HOST=
TEST_SQL_PORT=
TEST_SQL_USER=
TEST_SQL_PASSWORD=
TEST_SQL_DATABASE=
TEST_SQL_DIALECT=
