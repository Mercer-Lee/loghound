TLS_ACCESS_KEY_SECRET=
TLS_SESSION_TOKEN=
TLS_HOST=

# ============================================================
# Webhook task query (e.g. n8n, internal workflow engine)
# ============================================================
WEBHOOK_API_URL=
WEBHOOK_ERROR_API_URL=
WEBHOOK_TOKEN=

# ============================================================
# User ID lookup (MongoDB)
# ============================================================
