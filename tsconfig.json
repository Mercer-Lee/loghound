{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "scripts",
    "declaration": false
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
